# Bloqueia QUALQUER acesso direto a arquivos desta pasta via web.
# Os arquivos só devem ser servidos através de /api/uploads/get.php,
# que checa autenticação e permissão.

<IfModule mod_authz_core.c>
  Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
  Order deny,allow
  Deny from all
</IfModule>

# Por segurança extra, desabilita execução de PHP nesta pasta
# (caso alguém faça upload de algo malicioso renomeado).
<FilesMatch "\.(php|phtml|phar|sh|cgi|pl|py)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>
